{
  "name": "os-monitor",
  "version": "1.0.0",
  "description": "macOS Menu Bar CPU Monitor",
  "main": "dist/main.js",
  "scripts": {
    "dev": "bun build src/main.ts --target=node --format=cjs --external=electron --external=macos-temperature-sensor --outfile=dist/main.js --watch & nodemon --watch dist/main.js --exec 'electron .'",
    "build": "bun build src/main.ts --target=node --format=cjs --external=electron --external=macos-temperature-sensor --outfile=dist/main.js",
    "start": "electron .",
    "package": "electron-builder --publish never"
  },
  "dependencies": {
    "systeminformation": "^5.23.0"
  },
  "optionalDependencies": {
    "macos-temperature-sensor": "^1.0.4"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "@types/node": "^22.0.0",
    "nodemon": "^3.0.0"
  },
  "trustedDependencies": [
    "macos-temperature-sensor"
  ],
  "build": {
    "appId": "com.saissaken.os-monitor",
    "productName": "OS Monitor",
    "icon": "resources/icon-512.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
